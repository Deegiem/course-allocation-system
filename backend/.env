# Server
PORT=5000
NODE_ENV=development

# Database - PostgreSQL
DATABASE_URL="postgresql://postgres:deegiem%2606@localhost:5432/course_allocation"

# Replace 'postgres' and 'password' with your actual username and password
# If your password has special characters, URL-encode it

# JWT
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRES_IN="7d"

# API
API_PREFIX="/api/v1"
CORS_ORIGIN="http://localhost:3000"

# Logging
LOG_LEVEL="info"