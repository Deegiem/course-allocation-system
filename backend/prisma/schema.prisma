generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rank {
  PROFESSOR
  READER
  SENIOR_LECTURER
  LECTURER_I
  LECTURER_II
  ASSISTANT_LECTURER
  GRADUATE_ASSISTANT
  ADJUNCT_LECTURER
  VISITING_LECTURER
}

enum TeachingStyle {
  LECTURE_BASED
  PRACTICAL_BASED
  MIXED_METHOD
  RESEARCH_ORIENTED
  STUDENT_CENTRIC
}

enum CourseNature {
  THEORY_ONLY
  THEORY_AND_PRACTICAL
  PRACTICAL_ONLY
}

enum AllocationStatus {
  PENDING
  AUTO_ALLOCATED
  OVERRIDDEN
  APPROVED
  REJECTED
}

enum OverrideAction {
  FORCE_ASSIGN
  REJECT
  MODIFY
}

enum ReportType {
  ALLOCATION_REPORT
  WORKLOAD_SUMMARY
  LEVEL_BASED_LIST
}


model Lecturer {
  id                Int      @id @default(autoincrement())
  staffId           String   @unique
  name              String
  email             String   @unique
  rank              String
  specialization    String
  teachingStyle     String
  yearsOfExperience Int
  maxHours          Int      @default(18)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  allocations Allocation[]

  @@map("lecturers")
}

model Course {
  id              Int      @id @default(autoincrement())
  code            String   @unique
  title           String
  units           Int
  level           Int
  nature          String
  lectureHours    Int
  practicalHours  Int
  status          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  allocations Allocation[]

  @@map("courses")
}

model Allocation {
  id              Int      @id @default(autoincrement())
  lecturerId      Int
  courseId        Int
  score           Float?
  status          String   @default("PENDING")
  overrideReason  String?
  assignedBy      String
  assignedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lecturer Lecturer @relation(fields: [lecturerId], references: [id])
  course   Course   @relation(fields: [courseId], references: [id])

  @@unique([lecturerId, courseId])
  @@map("allocations")
}

model Policy {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("policies")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  actionType  String
  entity      String
  entityId    Int
  payload     String?
  timestamp   DateTime @default(now())
  lecturerId  Int?
  courseId    Int?
  allocationId Int?

  @@map("audit_logs")
}

model Report {
  id          Int      @id @default(autoincrement())
  generatedBy String
  generatedAt DateTime @default(now())
  reportType  String
  data        String
  filePath    String?

  @@map("reports")
}